# Copy to .env and fill in your keys:  cp .env.example .env
# (.env is gitignored — never commit real keys.)

# --- LLM providers ---
GROQ_API_KEY=your_groq_key_here

# Ollama (local fallback). From INSIDE a container, host Ollama is at
# host.docker.internal, NOT localhost. Uncomment the container form when the
# backend needs to reach an Ollama running on your host:
OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

DEFAULT_LLM_PROVIDER=groq

# --- Sandbox ---
SANDBOX_TIMEOUT=10
